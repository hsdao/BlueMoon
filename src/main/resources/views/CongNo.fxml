<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox style="-fx-background-color: -color-bg-subtle;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.CongNoController">
    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <children>
                <Label text="Báo cáo công nợ">
                    <font><Font name="System Bold" size="24.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="txtTimKiem" prefWidth="240.0" promptText="Tìm mã hộ, chủ hộ..."
                           style="-fx-border-color: -color-border-default; -fx-background-color: -color-bg-default; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8;" />
                <Button fx:id="btnXuatPDF" mnemonicParsing="false" onAction="#onXuatPDFClick" text="Xuất PDF"
                        style="-fx-background-color: #2DA44E; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16 8 16; -fx-background-radius: 4; -fx-cursor: hand;" />
                <Button fx:id="btnLamMoi" mnemonicParsing="false" onAction="#onLamMoiClick" text="Làm mới"
                        style="-fx-background-color: #0969DA; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16 8 16; -fx-background-radius: 4; -fx-cursor: hand;" />
            </children>
            <VBox.margin><Insets bottom="12.0" /></VBox.margin>
        </HBox>

        <Label fx:id="lblTongHop" style="-fx-font-size: 14px; -fx-text-fill: -color-danger-fg; -fx-font-weight: bold;" >
            <VBox.margin><Insets bottom="10.0" /></VBox.margin>
        </Label>

        <TableView fx:id="tblCongNo" VBox.vgrow="ALWAYS">
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            <columns>
                <TableColumn fx:id="colMaHo"      text="Mã hộ" prefWidth="90.0" />
                <TableColumn fx:id="colTenChuHo"  text="Chủ hộ" prefWidth="170.0" />
                <TableColumn fx:id="colSoKhoan"   text="Số khoản nợ" prefWidth="100.0" />
                <TableColumn fx:id="colTongNo"    text="Tổng nợ" prefWidth="140.0" />
                <TableColumn fx:id="colDanhSach"  text="Các khoản còn nợ" prefWidth="320.0" />
            </columns>
        </TableView>
    </children>
</VBox>
