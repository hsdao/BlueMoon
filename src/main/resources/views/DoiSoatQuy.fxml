<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="app-bg" spacing="16.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.DoiSoatQuyController">
    <stylesheets><URL value="@../css/app.css" /></stylesheets>
    <padding><Insets top="30.0" right="30.0" bottom="30.0" left="30.0" /></padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="14.0">
            <children>
                <Label text="Đối soát quỹ" styleClass="page-title" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Làm mới" onAction="#onRefresh" mnemonicParsing="false" styleClass="btn-secondary" />
            </children>
        </HBox>
        <Label fx:id="lblTong" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1F883D;" />

        <Label text="Tổng thu theo NGƯỜI THU" style="-fx-font-weight: bold; -fx-text-fill: #1E3A5F;" />
        <TableView fx:id="tblNguoiThu" prefHeight="240.0">
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            <columns>
                <TableColumn fx:id="colNgNhom" text="Người thu" />
                <TableColumn fx:id="colNgSL" text="Số giao dịch" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colNgTong" text="Tổng tiền (VNĐ)" style="-fx-alignment: CENTER_RIGHT;" />
            </columns>
        </TableView>

        <Label text="Tổng thu theo NGÀY" style="-fx-font-weight: bold; -fx-text-fill: #1E3A5F;" />
        <TableView fx:id="tblNgay" VBox.vgrow="ALWAYS">
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            <columns>
                <TableColumn fx:id="colNgayNhom" text="Ngày" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colNgaySL" text="Số giao dịch" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colNgayTong" text="Tổng tiền (VNĐ)" style="-fx-alignment: CENTER_RIGHT;" />
            </columns>
        </TableView>
    </children>
</VBox>
