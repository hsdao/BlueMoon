<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<!--Form thêm/sửa hộ khẩu-->
<VBox prefWidth="450.0" spacing="20.0" style="-fx-background-color: white; -fx-border-color: #D0D7DE; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.HoKhauFormController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>
    <children>
        <!-- Tiêu đề form -->
        <Label fx:id="lblTitle" text="Thêm Hộ Khẩu Mới" textFill="#24292f">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
        </Label>
        <!-- Bảng với 2 cột: label và input -->
        <GridPane hgap="15.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints minWidth="-Infinity" prefWidth="130.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <children>
                <!-- Trường Mã Hộ Khẩu (bắt buộc) -->
                <Label text="Mã Hộ Khẩu (*):" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtMaHo" promptText="Mã hộ khẩu" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <!-- Trường Số Điện Thoại (bắt buộc) -->
                <Label text="Số điện thoại (*):" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtSdt" promptText="Nhập 10-11 số" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <!-- Trường Địa Chỉ (bắt buộc) -->
                <Label text="Địa chỉ (*):" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="txtDiaChi" promptText="Số nhà, đường..." GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <!-- Trường Ngày Tạo (tùy chọn) -->
                <Label text="Ngày tạo:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <DatePicker fx:id="dpNgayTao" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <!-- Trường Trạng Thái (tùy chọn) -->
                <Label text="Trạng thái:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <ComboBox fx:id="cbTrangThai" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                <!-- Trường Ghi Chú (tùy chọn, textarea) -->
                <Label text="Ghi chú:" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.valignment="TOP" />
                <TextArea fx:id="txtGhiChu" prefRowCount="3" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            </children>
        </GridPane>

        <!-- Nút bấm: Hủy bỏ và Lưu thông tin -->
        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
                <!-- Nút Hủy bỏ: quay lại, không lưu dữ liệu -->
                <Button mnemonicParsing="false" onAction="#handleCancel" style="-fx-background-color: #F6F8FA; -fx-border-color: #D0D7DE; -fx-border-radius: 4; -fx-cursor: hand;" text="Hủy bỏ" />
                <!-- Nút Lưu thông tin: xác nhận lưu dữ liệu vào DB -->
                <Button mnemonicParsing="false" onAction="#handleSave" style="-fx-background-color: #5B4B8A; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Lưu thông tin" />
            </children>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>