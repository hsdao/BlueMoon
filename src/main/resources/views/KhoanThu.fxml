<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<AnchorPane prefHeight="964.0" prefWidth="1190.0" style="-fx-background-color: #F6F8FA;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.KhoanThuController">
   <children>
      <VBox layoutX="30.0" layoutY="30.0" spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="20.0">
               <children>
                  <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #24292F;" text="Thống Kê Khoản Thu" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <TextField fx:id="txtTimKiem" prefHeight="40.0" prefWidth="250.0" promptText="Tìm kiếm mã, tên khoản thu..." style="-fx-border-color: #D0D7DE; -fx-border-radius: 4; -fx-background-radius: 4;" />
                  <HBox alignment="CENTER_RIGHT" spacing="15.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Button fx:id="btnThemMoi" mnemonicParsing="false" onAction="#onThemMoiClick" prefHeight="40.0" text="Thêm Khoản Thu" style="-fx-background-color: #0969DA; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
                        <Button fx:id="btnSua" mnemonicParsing="false" onAction="#onSuaClick" prefHeight="40.0" text="Sửa" style="-fx-background-color: #0969DA; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
                        <Button fx:id="btnXoa" mnemonicParsing="false" onAction="#onXoaClick" prefHeight="40.0" text="Xóa" style="-fx-background-color: #82071E; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
                     </children>
                  </HBox>
               </children>
            </HBox>
            <TableView fx:id="tblKhoanThu" fixedCellSize="50.0" VBox.vgrow="ALWAYS">
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
               <columns>
                  <TableColumn text="ID" style="-fx-alignment: CENTER;">
                     <cellValueFactory><PropertyValueFactory property="id" /></cellValueFactory>
                  </TableColumn>
                  <TableColumn text="Mã Khoản" style="-fx-alignment: CENTER;">
                     <cellValueFactory><PropertyValueFactory property="maKhoan" /></cellValueFactory>
                  </TableColumn>
                  <TableColumn text="Tên Khoản Thu" style="-fx-alignment: CENTER;">
                     <cellValueFactory><PropertyValueFactory property="tenKhoan" /></cellValueFactory>
                  </TableColumn>
                  <TableColumn text="Loại" style="-fx-alignment: CENTER;">
                     <cellValueFactory><PropertyValueFactory property="loai" /></cellValueFactory>
                  </TableColumn>
                  <TableColumn text="Số Tiền" style="-fx-alignment: CENTER;">
                     <cellValueFactory><PropertyValueFactory property="soTien" /></cellValueFactory>
                  </TableColumn>
                  <TableColumn text="Hạn Nộp" style="-fx-alignment: CENTER;">
                     <cellValueFactory><PropertyValueFactory property="hanNop" /></cellValueFactory>
                  </TableColumn>
                  <TableColumn text="Trạng Thái" style="-fx-alignment: CENTER;">
                     <cellValueFactory><PropertyValueFactory property="trangThai" /></cellValueFactory>
                  </TableColumn>
               </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
