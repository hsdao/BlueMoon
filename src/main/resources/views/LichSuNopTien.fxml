<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="964.0" prefWidth="1190.0"
            style="-fx-background-color: #F6F8FA;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.LichSuNopTienController">
   <children>
      <VBox layoutX="30.0" layoutY="30.0" spacing="20.0"
            AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0"
            AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
         <children>

            <!-- Tiêu đề -->
            <HBox alignment="CENTER_LEFT" prefHeight="50.0">
               <children>
                  <Label text="Lịch Sử Nộp Phí"
                         style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #24292F;" />
               </children>
            </HBox>

            <!-- Thanh lọc -->
            <HBox alignment="CENTER_LEFT" spacing="15.0"
                  style="-fx-background-color: white; -fx-border-color: #D0D7DE; -fx-border-radius: 6; -fx-background-radius: 6;">
               <padding><Insets topRightBottomLeft="14.0"/></padding>
               <children>
                  <Label text="Khoản thu:" style="-fx-font-weight: bold; -fx-text-fill: #24292F;" />
                  <ComboBox fx:id="cmbLocKhoanThu" prefHeight="36.0" prefWidth="260.0"
                            promptText="— Tất cả —" />

                  <Label text="Hộ khẩu:" style="-fx-font-weight: bold; -fx-text-fill: #24292F;" />
                  <ComboBox fx:id="cmbLocHoKhau" prefHeight="36.0" prefWidth="220.0"
                            promptText="— Tất cả —" />

                  <TextField fx:id="txtTimKiem" prefHeight="36.0" prefWidth="220.0"
                             promptText="Tìm người thu, ghi chú..."
                             style="-fx-border-color: #D0D7DE; -fx-border-radius: 4; -fx-background-radius: 4;" />

                  <HBox HBox.hgrow="ALWAYS" />

                  <Button fx:id="btnLamMoi" mnemonicParsing="false"
                          onAction="#onLamMoiClick" prefHeight="36.0" prefWidth="100.0"
                          text="Làm mới"
                          style="-fx-background-color: #0969DA; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
               </children>
            </HBox>

            <!-- Bảng lịch sử -->
            <TableView fx:id="tblLichSu" fixedCellSize="48.0" VBox.vgrow="ALWAYS">
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
               <columns>
                  <TableColumn fx:id="colStt" text="STT" prefWidth="60.0"
                               style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colKhoanThuId" text="Khoản Thu ID"
                               style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colHoKhauId" text="Hộ Khẩu ID"
                               style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colSoTien" text="Số Tiền (VNĐ)"
                               style="-fx-alignment: CENTER_RIGHT;" />
                  <TableColumn fx:id="colNgayNop" text="Ngày Nộp"
                               style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colNguoiThu" text="Người Thu"
                               style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colGhiChu" text="Ghi Chú"
                               style="-fx-alignment: CENTER_LEFT;" />
                  <TableColumn fx:id="colHanhDong" text="Hanh Dong" prefWidth="90.0"
                               style="-fx-alignment: CENTER;" />
               </columns>
            </TableView>

         </children>
      </VBox>
   </children>
</AnchorPane>
