<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="1024.0" prefWidth="1440.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.MainLayoutController">
    <stylesheets>
        <URL value="@../css/app.css" />
    </stylesheets>
    <children>

        <!-- ===== SIDEBAR 250px ===== -->
        <VBox prefWidth="250.0" prefHeight="1024.0" styleClass="sidebar">

            <!-- Branding -->
            <VBox alignment="CENTER" prefHeight="78.0"
                  style="-fx-border-color: transparent transparent #2D5A8E transparent; -fx-border-width: 0 0 1 0;">
                <padding><Insets top="14.0" right="16.0" bottom="14.0" left="16.0"/></padding>
                <children>
                    <Label text="BLUEMOON"
                           style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                    <Label text="Quản lý thu phí chung cư"
                           style="-fx-text-fill: #8EA8C3; -fx-font-size: 10px;"
                           wrapText="true" alignment="CENTER"/>
                </children>
            </VBox>

            <!-- Nav items -->
            <VBox fx:id="navBox" spacing="1.0" VBox.vgrow="ALWAYS">
                <padding><Insets top="10.0" left="8.0" right="8.0" bottom="10.0"/></padding>
                <children>
                    <Label text="QUẢN LÝ" styleClass="nav-section"/>
                    <Button fx:id="btnDashboard" text="Tổng quan" prefWidth="234.0" prefHeight="40.0"
                            onAction="#goDashboard" mnemonicParsing="false" styleClass="nav-button"/>
                    <Button text="Hộ khẩu" prefWidth="234.0" prefHeight="40.0"
                            onAction="#goHoKhau" mnemonicParsing="false" styleClass="nav-button"/>
                    <Button text="Sơ đồ căn hộ" prefWidth="234.0" prefHeight="40.0"
                            onAction="#goSoDoPhong" mnemonicParsing="false" styleClass="nav-button"/>
                    <Button text="Nhân khẩu" prefWidth="234.0" prefHeight="40.0"
                            onAction="#goNhanKhau" mnemonicParsing="false" styleClass="nav-button"/>

                    <Label text="THU PHÍ" styleClass="nav-section"/>
                    <Button text="Khoản thu" prefWidth="234.0" prefHeight="40.0"
                            onAction="#goKhoanThu" mnemonicParsing="false" styleClass="nav-button"/>
                    <Button text="Thu phí" prefWidth="234.0" prefHeight="40.0"
                            onAction="#goThuPhi" mnemonicParsing="false" styleClass="nav-button"/>
                    <Button text="Công nợ" prefWidth="234.0" prefHeight="40.0"
                            onAction="#goCongNo" mnemonicParsing="false" styleClass="nav-button"/>
                    <Button text="Đối soát quỹ" prefWidth="234.0" prefHeight="40.0"
                            onAction="#goDoiSoat" mnemonicParsing="false" styleClass="nav-button"/>
                    <Button text="Lịch sử nộp phí" prefWidth="234.0" prefHeight="40.0"
                            onAction="#goLichSuNopTien" mnemonicParsing="false" styleClass="nav-button"/>
                    <Button text="Thống kê" prefWidth="234.0" prefHeight="40.0"
                            onAction="#goThongKe" mnemonicParsing="false" styleClass="nav-button"/>

                    <Label text="CƯ TRÚ" styleClass="nav-section"/>
                    <Button text="Tạm trú / Tạm vắng" prefWidth="234.0" prefHeight="40.0"
                            onAction="#goTamTru" mnemonicParsing="false" styleClass="nav-button"/>
                    <Button text="Biến động nhân khẩu" prefWidth="234.0" prefHeight="40.0"
                            onAction="#goLichSuBienDong" mnemonicParsing="false" styleClass="nav-button"/>

                    <Button text="Tìm kiếm" prefWidth="234.0" prefHeight="40.0"
                            onAction="#goTimKiem" mnemonicParsing="false" styleClass="nav-button"/>

                    <!-- Admin-only -->
                    <Label fx:id="lblAdminSection" text="QUẢN TRỊ" styleClass="nav-section"/>
                    <Button fx:id="btnQuanLyTK" text="Quản lý tài khoản" prefWidth="234.0" prefHeight="40.0"
                            onAction="#goQuanLyTaiKhoan" mnemonicParsing="false" styleClass="nav-button"/>
                    <Button fx:id="btnNhatKy" text="Nhật ký thao tác" prefWidth="234.0" prefHeight="40.0"
                            onAction="#goNhatKy" mnemonicParsing="false" styleClass="nav-button"/>
                </children>
            </VBox>

            <!-- Bottom: settings + user + logout -->
            <VBox fx:id="navBottom"
                  style="-fx-border-color: #2D5A8E transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                <padding><Insets top="8.0" left="8.0" right="8.0" bottom="12.0"/></padding>
                <children>
                    <Button text="Cài đặt" prefWidth="234.0" prefHeight="36.0"
                            onAction="#goSettings" mnemonicParsing="false" styleClass="nav-button"/>
                    <Button text="Đổi mật khẩu" prefWidth="234.0" prefHeight="36.0"
                            onAction="#goChangePassword" mnemonicParsing="false" styleClass="nav-button"/>
                    <HBox spacing="6.0" alignment="CENTER_LEFT">
                        <padding><Insets top="6.0" left="14.0" right="8.0" bottom="4.0"/></padding>
                        <children>
                            <VBox>
                                <children>
                                    <Label fx:id="lblUserName"
                                           style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                    <Label fx:id="lblUserRole"
                                           style="-fx-text-fill: #8EA8C3; -fx-font-size: 10px;"/>
                                </children>
                            </VBox>
                        </children>
                    </HBox>
                    <Button text="Đăng xuất" prefWidth="234.0" prefHeight="38.0"
                            onAction="#handleLogout" mnemonicParsing="false"
                            style="-fx-background-color: #82071E; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6; -fx-padding: 0 0 0 14; -fx-alignment: CENTER_LEFT;"/>
                </children>
            </VBox>
        </VBox>

        <!-- ===== CONTENT AREA ===== -->
        <StackPane fx:id="contentArea" HBox.hgrow="ALWAYS" styleClass="app-bg"/>

    </children>
</HBox>
