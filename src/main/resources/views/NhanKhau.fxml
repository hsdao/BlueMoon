<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="1024.0" prefWidth="1440.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.NhanKhauController">
    <children>
        <!-- Sidebar -->
        <VBox prefWidth="250.0" style="-fx-background-color: #1E3A5F;" />

        <!-- Main -->
        <VBox HBox.hgrow="ALWAYS">
            <children>
                <!-- Header bar -->
                <HBox minHeight="60.0" prefHeight="60.0" style="-fx-background-color: #1E3A5F;" />

                <!-- Content -->
                <VBox style="-fx-background-color: #F6F8FA;" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                    </padding>
                    <children>
                        <!-- Title + Filter + Search + Add -->
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Label text="Quản lý nhân khẩu" textFill="#24292F">
                                    <font><Font name="System Bold" size="24.0" /></font>
                                </Label>
                                <Region HBox.hgrow="ALWAYS" />
                                <ComboBox fx:id="cmbFilterHoKhau"
                                          prefWidth="220.0"
                                          promptText="-- Lọc theo hộ khẩu --"
                                          style="-fx-border-color: #D0D7DE; -fx-background-color: white;
                                                 -fx-border-radius: 4; -fx-background-radius: 4;" />
                                <TextField fx:id="searchField"
                                           prefWidth="220.0"
                                           promptText="Tìm họ tên, CCCD, SĐT..."
                                           style="-fx-border-color: #D0D7DE; -fx-background-color: white;
                                                  -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8;" />
                                <Button fx:id="btnThemMoi"
                                        mnemonicParsing="false"
                                        onAction="#handleAdd"
                                        style="-fx-background-color: #0969DA; -fx-text-fill: white;
                                               -fx-font-weight: bold; -fx-padding: 8 16 8 16;
                                               -fx-background-radius: 4; -fx-cursor: hand;"
                                        text="+ Thêm mới" />
                            </children>
                            <VBox.margin><Insets bottom="20.0" /></VBox.margin>
                        </HBox>

                        <!-- Table nhân khẩu -->
                        <TableView fx:id="tableNhanKhau" VBox.vgrow="ALWAYS">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colId"          text="ID" />
                                <TableColumn fx:id="colHoKhauId"    text="Mã hộ" />
                                <TableColumn fx:id="colHoTen"       text="Họ và tên" />
                                <TableColumn fx:id="colNgaySinh"    text="Ngày sinh" />
                                <TableColumn fx:id="colGioiTinh"    text="Giới tính" />
                                <TableColumn fx:id="colCccd"        text="CCCD" />
                                <TableColumn fx:id="colSoDienThoai" text="Điện thoại" />
                                <TableColumn fx:id="colQuanHe"      text="Quan hệ" />
                                <TableColumn fx:id="colTrangThai"   text="Trạng thái" />
                                <TableColumn fx:id="colHanhDong"    text="Hành động" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</HBox>
