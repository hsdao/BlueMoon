<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox style="-fx-background-color: -color-bg-subtle;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.NhatKyController">
    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <children>
                <Label text="Nhật ký thao tác">
                    <font><Font name="System Bold" size="24.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="txtTimKiem" prefWidth="260.0"
                           promptText="Tìm theo tài khoản, đối tượng, mô tả..."
                           style="-fx-border-color: -color-border-default; -fx-background-color: -color-bg-default; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8;" />
                <Button fx:id="btnLamMoi" mnemonicParsing="false" onAction="#onLamMoiClick"
                        text="Làm mới"
                        style="-fx-background-color: #0969DA; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16 8 16; -fx-background-radius: 4; -fx-cursor: hand;" />
            </children>
            <VBox.margin><Insets bottom="20.0" /></VBox.margin>
        </HBox>

        <TableView fx:id="tblNhatKy" VBox.vgrow="ALWAYS">
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            <columns>
                <TableColumn fx:id="colThoiGian" text="Thời gian" prefWidth="160.0" />
                <TableColumn fx:id="colUsername" text="Tài khoản" prefWidth="110.0" />
                <TableColumn fx:id="colHanhDong" text="Hành động" prefWidth="110.0" />
                <TableColumn fx:id="colDoiTuong" text="Đối tượng" prefWidth="110.0" />
                <TableColumn fx:id="colMoTa"     text="Mô tả" prefWidth="380.0" />
            </columns>
        </TableView>
    </children>
</VBox>
