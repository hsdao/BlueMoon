<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="964.0" prefWidth="1190.0"
            style="-fx-background-color: #F6F8FA;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.QuanLyTaiKhoanController">
   <children>
      <VBox layoutX="30.0" layoutY="30.0" spacing="20.0"
            AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0"
            AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
         <children>

            <!-- Tieu de -->
            <HBox alignment="CENTER_LEFT">
               <children>
                  <Label text="Quản Lý Tài Khoản"
                         style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #24292F;" />
               </children>
            </HBox>

            <!-- Form them moi tai khoan -->
            <VBox spacing="14.0"
                  style="-fx-background-color: white; -fx-border-color: #D0D7DE;
                         -fx-border-radius: 6; -fx-background-radius: 6;">
               <padding><Insets topRightBottomLeft="20.0"/></padding>
               <children>
                  <Label text="Thêm tài khoản mới"
                         style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1E3A5F;" />
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <children>
                        <Label text="Tên đăng nhập:" style="-fx-font-weight: bold; -fx-min-width: 110;" />
                        <TextField fx:id="txtUsername" prefWidth="220.0" prefHeight="36.0"
                                   promptText="Nhập tên đăng nhập..."
                                   style="-fx-border-color: #D0D7DE; -fx-border-radius: 4; -fx-background-radius: 4;" />
                        <Label text="Mật khẩu:" style="-fx-font-weight: bold; -fx-min-width: 80;" />
                        <PasswordField fx:id="txtPassword" prefWidth="220.0" prefHeight="36.0"
                                       promptText="Nhập mật khẩu..."
                                       style="-fx-border-color: #D0D7DE; -fx-border-radius: 4; -fx-background-radius: 4;" />
                        <Label text="Vai trò:" style="-fx-font-weight: bold; -fx-min-width: 60;" />
                        <ComboBox fx:id="cmbRole" prefWidth="140.0" prefHeight="36.0"
                                  promptText="-- Chọn vai trò --" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnThem" text="+ Thêm mới"
                                onAction="#onThemClick" prefHeight="36.0" prefWidth="110.0"
                                style="-fx-background-color: #0969DA; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
                     </children>
                  </HBox>
               </children>
            </VBox>

            <!-- Thanh tim kiem + lam moi -->
            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <children>
                  <Label text="Danh sách tài khoản"
                         style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1E3A5F;" />
                  <Region HBox.hgrow="ALWAYS" />
                  <TextField fx:id="txtTimKiem" prefHeight="36.0" prefWidth="260.0"
                             promptText="Tìm kiếm tên đăng nhập, vai trò..."
                             style="-fx-border-color: #D0D7DE; -fx-border-radius: 4; -fx-background-radius: 4;" />
                  <Button fx:id="btnLamMoi" text="Làm mới"
                          onAction="#onLamMoiClick" prefHeight="36.0" prefWidth="90.0"
                          style="-fx-background-color: #6E7781; -fx-text-fill: white;
                                 -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
               </children>
            </HBox>

            <!-- Bang tai khoan -->
            <TableView fx:id="tblUsers" fixedCellSize="46.0" VBox.vgrow="ALWAYS"
                       style="-fx-border-color: #D0D7DE; -fx-border-radius: 5;">
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
               <columns>
                  <TableColumn fx:id="colId"       text="ID"       prefWidth="60.0"
                               style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colUsername" text="Tên đăng nhập" prefWidth="250.0"
                               style="-fx-alignment: CENTER_LEFT;" />
                  <TableColumn fx:id="colRole"     text="Vai trò"     prefWidth="120.0"
                               style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colHanhDong" text="Hành động"
                               style="-fx-alignment: CENTER;" />
               </columns>
            </TableView>

         </children>
      </VBox>
   </children>
</AnchorPane>
