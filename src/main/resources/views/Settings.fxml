<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="640.0"
            style="-fx-background-color: #F6F8FA;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.SettingsController">
    <children>
        <VBox spacing="24.0"
              AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0">
            <padding><Insets bottom="32.0" left="40.0" right="40.0" top="32.0" /></padding>
            <children>

                <!-- Tiêu đề -->
                <Label text="Cài đặt hệ thống" textFill="#24292f">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>
                <Separator />

                <!-- Theme Switcher -->
                <VBox spacing="10.0"
                      style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-border-color: #D0D7DE; -fx-border-radius: 10;">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <Label text="🎨  Giao diện (Theme)" textFill="#24292f">
                            <font><Font name="System Bold" size="15.0" /></font>
                        </Label>
                        <Label text="Chọn theme hiển thị cho toàn bộ ứng dụng. Thay đổi có hiệu lực ngay lập tức." textFill="#57606a">
                            <font><Font size="12.0" /></font>
                        </Label>
                        <HBox alignment="CENTER_LEFT" spacing="16.0">
                            <children>
                                <ComboBox fx:id="cmbTheme" prefWidth="260.0" prefHeight="36.0"
                                          promptText="-- Chọn theme --"
                                          style="-fx-background-color: WHITE; -fx-border-color: #D0D7DE; -fx-border-radius: 5;" />
                                <Button fx:id="btnApply" text="Áp dụng" onAction="#handleApply"
                                        style="-fx-background-color: #0969DA; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                    <padding><Insets bottom="8.0" left="18.0" right="18.0" top="8.0" /></padding>
                                </Button>
                            </children>
                        </HBox>
                        <Label fx:id="lblStatus" text="" textFill="#2da44e">
                            <font><Font size="12.0" /></font>
                        </Label>
                    </children>
                </VBox>

                <!-- Thông tin phiên bản -->
                <VBox spacing="6.0"
                      style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-border-color: #D0D7DE; -fx-border-radius: 10;">
                    <padding><Insets bottom="16.0" left="20.0" right="20.0" top="16.0" /></padding>
                    <children>
                        <Label text="ℹ️  Thông tin ứng dụng" textFill="#24292f">
                            <font><Font name="System Bold" size="15.0" /></font>
                        </Label>
                        <Label text="BlueMoon v1.0 – Hệ thống quản lý thu phí chung cư" textFill="#57606a">
                            <font><Font size="12.0" /></font>
                        </Label>
                        <Label text="JavaFX 21 · AtlantaFX 2.1.0 · MySQL 8.4 · iText 8" textFill="#57606a">
                            <font><Font size="12.0" /></font>
                        </Label>
                    </children>
                </VBox>

            </children>
        </VBox>
    </children>
</AnchorPane>
