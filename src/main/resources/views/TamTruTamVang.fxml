<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="964.0" prefWidth="1190.0"
            style="-fx-background-color: #F6F8FA;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.TamTruController">
   <children>
      <VBox spacing="20.0"
            AnchorPane.bottomAnchor="30.0"
            AnchorPane.leftAnchor="30.0"
            AnchorPane.rightAnchor="30.0"
            AnchorPane.topAnchor="30.0">
         <children>

            <!-- Tiêu đề -->
            <HBox alignment="CENTER_LEFT" prefHeight="60.0">
               <children>
                  <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #24292F;"
                         text="Quản lý Tạm trú / Tạm vắng">
                     <font><Font name="System Bold" size="24.0" /></font>
                  </Label>
               </children>
            </HBox>

            <!-- Thanh công cụ: tìm kiếm + lọc + thêm mới -->
            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <children>
                  <TextField fx:id="txtTimKiem"
                             prefHeight="38.0" prefWidth="240.0"
                             promptText="Tìm theo họ tên nhân khẩu..."
                             style="-fx-border-color: #D0D7DE; -fx-border-radius: 4;
                                    -fx-background-radius: 4; -fx-padding: 6;" />

                  <ComboBox fx:id="cmbLoai" prefHeight="38.0" prefWidth="160.0"
                            promptText="Lọc theo loại" />

                  <Region HBox.hgrow="ALWAYS" />

                  <Button fx:id="btnThemMoi"
                          mnemonicParsing="false"
                          onAction="#onThemMoiClick"
                          prefHeight="38.0"
                          text="+ Thêm mới"
                          style="-fx-background-color: #0969DA; -fx-text-fill: white;
                                 -fx-font-weight: bold; -fx-background-radius: 6;
                                 -fx-cursor: hand; -fx-padding: 6 16 6 16;" />
               </children>
            </HBox>

            <!-- TableView -->
            <TableView fx:id="tblTamTru" fixedCellSize="48.0" VBox.vgrow="ALWAYS">
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
               <columns>
                  <TableColumn fx:id="colId"       text="ID"          prefWidth="50.0"
                               style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colLoai"     text="Loại"        prefWidth="100.0"
                               style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colHoTen"    text="Họ tên nhân khẩu" prefWidth="180.0" />
                  <TableColumn fx:id="colTuNgay"   text="Từ ngày"     prefWidth="110.0"
                               style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colDenNgay"  text="Đến ngày"    prefWidth="110.0"
                               style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colDiaChi"   text="Địa chỉ tạm trú/vắng" prefWidth="200.0" />
                  <TableColumn fx:id="colLyDo"     text="Lý do"       prefWidth="150.0" />
                  <TableColumn fx:id="colTrangThai" text="Trạng thái" prefWidth="120.0"
                               style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colHanhDong" text="Hành động"   prefWidth="140.0"
                               style="-fx-alignment: CENTER;" />
               </columns>
            </TableView>

         </children>
         <padding>
            <Insets top="10.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
