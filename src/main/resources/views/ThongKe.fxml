<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="964.0" prefWidth="1190.0"
            style="-fx-background-color: #F6F8FA;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ThongKeController">
    <children>
        <VBox spacing="16.0"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding><Insets bottom="24.0" left="30.0" right="30.0" top="24.0" /></padding>
            <children>

                <!-- KHỐI 1: HEADER & CÔNG CỤ LỌC -->
                <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="15.0">
                    <children>
                        <Label text="Thống kê đóng góp &amp; Thu phí" textFill="#24292f">
                            <font><Font name="System Bold" size="24.0" /></font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="cmbKhoanThu" prefHeight="35.0" prefWidth="250.0"
                                  promptText="-- Chọn khoản thu --"
                                  style="-fx-background-color: WHITE; -fx-border-color: #D0D7DE; -fx-border-radius: 5;" />
                        <TextField fx:id="txtTimKiem" prefHeight="35.0" prefWidth="200.0"
                                   promptText="Tìm kiếm hộ khẩu..."
                                   style="-fx-border-color: #D0D7DE; -fx-border-radius: 5;" />
                        <Button fx:id="btnXuatPDF" mnemonicParsing="false" onAction="#handleXuatPDF"
                                style="-fx-background-color: #2DA44E;" text="Xuất PDF" textFill="WHITE">
                            <font><Font name="System Bold" size="14.0" /></font>
                            <padding><Insets bottom="8.0" left="12.0" right="12.0" top="8.0" /></padding>
                        </Button>
                        <Button fx:id="btnXuatExcel" mnemonicParsing="false" onAction="#handleXuatExcel"
                                style="-fx-background-color: #0969DA;" text="Xuất Excel" textFill="WHITE">
                            <font><Font name="System Bold" size="14.0" /></font>
                            <padding><Insets bottom="8.0" left="12.0" right="12.0" top="8.0" /></padding>
                        </Button>
                    </children>
                </HBox>

                <!-- KHỐI 2: THẺ TỔNG HỢP + PIE CHART -->
                <HBox spacing="20.0" prefHeight="200.0">
                    <children>
                        <!-- Card: Tổng hộ đã nộp -->
                        <VBox alignment="CENTER_LEFT" prefWidth="220.0"
                              style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-border-color: #D0D7DE; -fx-border-radius: 10;">
                            <padding><Insets left="20.0" /></padding>
                            <children>
                                <Label text="Hộ đã nộp" textFill="#57606a">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label fx:id="lblTongHoDaNop" text="0 hộ" textFill="#0969da">
                                    <font><Font name="System Bold" size="22.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                        <!-- Card: Tổng tiền -->
                        <VBox alignment="CENTER_LEFT" prefWidth="280.0"
                              style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-border-color: #D0D7DE; -fx-border-radius: 10;">
                            <padding><Insets left="20.0" /></padding>
                            <children>
                                <Label text="Tổng tiền thu được" textFill="#57606a">
                                    <font><Font size="13.0" /></font>
                                </Label>
                                <Label fx:id="lblTongTienThu" text="0 đ" textFill="#2da44e">
                                    <font><Font name="System Bold" size="22.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                        <!-- PieChart: Tỉ lệ đã/chưa nộp -->
                        <VBox style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-border-color: #D0D7DE; -fx-border-radius: 10;"
                              HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Tỉ lệ nộp phí" textFill="#24292f">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                    <VBox.margin><Insets left="16.0" top="12.0" /></VBox.margin>
                                </Label>
                                <PieChart fx:id="pieChart" labelsVisible="true"
                                          prefHeight="160.0" VBox.vgrow="ALWAYS"
                                          style="-fx-padding: 0;" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- KHỐI 3: BẢNG DỮ LIỆU -->
                <TableView fx:id="tvThongKe" VBox.vgrow="ALWAYS"
                           style="-fx-border-color: #D0D7DE; -fx-border-radius: 5;">
                    <columns>
                        <TableColumn fx:id="colMaHo"      prefWidth="110.0" text="Mã Hộ Khẩu" />
                        <TableColumn fx:id="colTenChuHo"  prefWidth="230.0" text="Tên Chủ Hộ" />
                        <TableColumn fx:id="colSoTienNop" prefWidth="180.0" text="Số Tiền Đã Nộp" />
                        <TableColumn fx:id="colNgayNop"   prefWidth="150.0" text="Ngày Nộp" />
                        <TableColumn fx:id="colTrangThai" prefWidth="130.0" text="Trạng Thái" />
                        <TableColumn fx:id="colGhiChu"    prefWidth="200.0" text="Ghi Chú" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

            </children>
        </VBox>
    </children>
</AnchorPane>