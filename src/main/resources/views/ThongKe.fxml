<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="964.0" prefWidth="1190.0" style="-fx-background-color: #F6F8FA;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ThongKeController">
    <children>
        <VBox layoutX="340.0" layoutY="142.0" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>

                <!-- KHỐI 1: HEADER & CÔNG CỤ LỌC -->
                <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="15.0">
                    <children>
                        <Label text="Thống kê đóng góp &amp; Thu phí" textFill="#24292f">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />

                        <!-- Bộ lọc chọn khoản thu -->
                        <ComboBox fx:id="cmbKhoanThu" prefHeight="35.0" prefWidth="250.0" promptText="-- Chọn khoản thu --" style="-fx-background-color: WHITE; -fx-border-color: #D0D7DE; -fx-border-radius: 5;" />

                        <!-- Ô tìm kiếm mã hộ/tên -->
                        <TextField fx:id="txtTimKiem" prefHeight="35.0" prefWidth="200.0" promptText="Tìm kiếm hộ khẩu..." style="-fx-border-color: #D0D7DE; -fx-border-radius: 5;" />

                        <!-- Nút xuất báo cáo -->
                        <Button fx:id="btnXuatPDF" mnemonicParsing="false" onAction="#handleXuatPDF" style="-fx-background-color: #2DA44E;" text="Xuất báo cáo PDF" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                            <padding>
                                <Insets bottom="8.0" left="15.0" right="15.0" top="8.0" />
                            </padding>
                        </Button>
                    </children>
                </HBox>

                <!-- KHỐI 2: THÔNG TIN TỔNG HỢP NHANH -->
                <HBox spacing="30.0">
                    <children>
                        <VBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-border-color: #D0D7DE; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets left="20.0" />
                            </padding>
                            <children>
                                <Label text="Tổng số hộ đã nộp" textFill="#57606a">
                                    <font>
                                        <Font size="14.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblTongHoDaNop" text="0 hộ" textFill="#0969da">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                        <VBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-background-color: WHITE; -fx-background-radius: 10; -fx-border-color: #D0D7DE; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets left="20.0" />
                            </padding>
                            <children>
                                <Label text="Tổng số tiền thu được" textFill="#57606a">
                                    <font>
                                        <Font size="14.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblTongTienThu" text="0 VNĐ" textFill="#2da44e">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- KHỐI 3: BẢNG DỮ LIỆU -->
                <TableView fx:id="tvThongKe" style="-fx-border-color: #D0D7DE; -fx-border-radius: 5;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colMaHo" prefWidth="120.0" text="Mã Hộ Khẩu" />
                        <TableColumn fx:id="colTenChuHo" prefWidth="250.0" text="Tên Chủ Hộ" />
                        <TableColumn fx:id="colSoTienNop" prefWidth="200.0" text="Số Tiền Đã Nộp" />
                        <TableColumn fx:id="colNgayNop" prefWidth="180.0" text="Ngày Nộp" />
                        <TableColumn fx:id="colTrangThai" prefWidth="150.0" text="Trạng Thái" />
                        <TableColumn fx:id="colGhiChu" prefWidth="200.0" text="Ghi Chú" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

            </children>
        </VBox>
    </children>
</AnchorPane>