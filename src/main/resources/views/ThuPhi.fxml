<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="964.0" prefWidth="1190.0"
            style="-fx-background-color: #F6F8FA;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ThuPhiController">
   <children>
      <VBox layoutX="30.0" layoutY="30.0" spacing="20.0"
            AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0"
            AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
         <children>

            <!-- Tiêu đề -->
            <HBox alignment="CENTER_LEFT" prefHeight="50.0">
               <children>
                  <Label text="Thu Phí"
                         style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #24292F;" />
               </children>
            </HBox>

            <!-- Form nhập liệu -->
            <VBox style="-fx-background-color: white; -fx-border-color: #D0D7DE; -fx-border-radius: 6; -fx-background-radius: 6;"
                  spacing="16">
               <padding><Insets topRightBottomLeft="20.0"/></padding>
               <children>

                  <Label text="Thông tin nộp tiền"
                         style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1E3A5F;" />

                  <GridPane hgap="20.0" vgap="14.0">
                     <columnConstraints>
                        <ColumnConstraints percentWidth="50.0" />
                        <ColumnConstraints percentWidth="50.0" />
                     </columnConstraints>

                     <!-- Hàng 1: Khoản thu | Hộ khẩu -->
                     <Label text="Khoản thu *" GridPane.columnIndex="0" GridPane.rowIndex="0"
                            style="-fx-font-weight: bold; -fx-text-fill: #24292F;" />
                     <ComboBox fx:id="cmbKhoanThu" maxWidth="Infinity"
                               prefHeight="38.0" promptText="— Chọn khoản thu —"
                               GridPane.columnIndex="0" GridPane.rowIndex="1" />

                     <Label text="Hộ khẩu *" GridPane.columnIndex="1" GridPane.rowIndex="0"
                            style="-fx-font-weight: bold; -fx-text-fill: #24292F;" />
                     <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <children>
                           <TextField fx:id="txtTimHoKhau" prefHeight="30.0"
                                      promptText="Gõ số phòng / tên chủ hộ để lọc..."
                                      style="-fx-border-color: #D0D7DE; -fx-border-radius: 4; -fx-background-radius: 4;" />
                           <ComboBox fx:id="cmbHoKhau" maxWidth="Infinity"
                                     prefHeight="38.0" promptText="— Chọn hộ khẩu —" />
                        </children>
                     </VBox>

                     <!-- Hàng 2: Số tiền | Ngày nộp -->
                     <Label text="Số tiền (VNĐ) *" GridPane.columnIndex="0" GridPane.rowIndex="2"
                            style="-fx-font-weight: bold; -fx-text-fill: #24292F;" />
                     <TextField fx:id="txtSoTien" maxWidth="Infinity" prefHeight="38.0"
                                promptText="Nhập số tiền..."
                                style="-fx-border-color: #D0D7DE; -fx-border-radius: 4; -fx-background-radius: 4;"
                                GridPane.columnIndex="0" GridPane.rowIndex="3" />

                     <Label text="Ngày nộp *" GridPane.columnIndex="1" GridPane.rowIndex="2"
                            style="-fx-font-weight: bold; -fx-text-fill: #24292F;" />
                     <DatePicker fx:id="dpNgayNop" maxWidth="Infinity" prefHeight="38.0"
                                 GridPane.columnIndex="1" GridPane.rowIndex="3" />

                     <!-- Hàng 3: Người thu | Ghi chú -->
                     <Label text="Người thu *" GridPane.columnIndex="0" GridPane.rowIndex="4"
                            style="-fx-font-weight: bold; -fx-text-fill: #24292F;" />
                     <TextField fx:id="txtNguoiThu" maxWidth="Infinity" prefHeight="38.0"
                                promptText="Tên người thu tiền..."
                                style="-fx-border-color: #D0D7DE; -fx-border-radius: 4; -fx-background-radius: 4;"
                                GridPane.columnIndex="0" GridPane.rowIndex="5" />

                     <Label text="Ghi chú" GridPane.columnIndex="1" GridPane.rowIndex="4"
                            style="-fx-font-weight: bold; -fx-text-fill: #24292F;" />
                     <TextArea fx:id="txtGhiChu" maxWidth="Infinity" prefHeight="75.0"
                               promptText="Ghi chú thêm (nếu có)..."
                               style="-fx-border-color: #D0D7DE; -fx-border-radius: 4; -fx-background-radius: 4;"
                               wrapText="true"
                               GridPane.columnIndex="1" GridPane.rowIndex="5" />
                  </GridPane>

                  <!-- Buttons -->
                  <HBox alignment="CENTER_RIGHT" spacing="12.0">
                     <children>
                        <Button fx:id="btnLamMoi" mnemonicParsing="false"
                                onAction="#onLamMoiClick" prefHeight="38.0" prefWidth="110.0"
                                text="Làm mới"
                                style="-fx-background-color: #6E7781; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
                        <Button fx:id="btnGhiNhan" mnemonicParsing="false"
                                onAction="#onGhiNhanClick" prefHeight="38.0" prefWidth="130.0"
                                text="Ghi nhận"
                                style="-fx-background-color: #0969DA; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
                     </children>
                  </HBox>

               </children>
            </VBox>

            <!-- Lịch sử nộp theo khoản thu đang chọn -->
            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <children>
                  <Label text="Lịch sử nộp theo khoản thu đang chọn"
                         style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1E3A5F;" />
                  <javafx.scene.layout.Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnInBienLai" mnemonicParsing="false" onAction="#onInBienLaiClick"
                          text="In biên lai" prefHeight="34.0"
                          style="-fx-background-color: #1F883D; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
                  <Button fx:id="btnSuaNop" mnemonicParsing="false" onAction="#onSuaNopClick"
                          text="Sửa dòng chọn" prefHeight="34.0"
                          style="-fx-background-color: #0969DA; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
                  <Button fx:id="btnXoaNop" mnemonicParsing="false" onAction="#onXoaNopClick"
                          text="Xóa dòng chọn" prefHeight="34.0"
                          style="-fx-background-color: #82071E; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
               </children>
            </HBox>

            <TableView fx:id="tblLichSu" fixedCellSize="48.0" VBox.vgrow="ALWAYS">
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
               <columns>
                  <TableColumn fx:id="colId" text="ID" prefWidth="60.0"
                               style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colHoKhauId" text="Phòng / Chủ hộ"
                               style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colSoTien" text="Số Tiền (VNĐ)"
                               style="-fx-alignment: CENTER_RIGHT;" />
                  <TableColumn fx:id="colNgayNop" text="Ngày Nộp"
                               style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colNguoiThu" text="Người Thu"
                               style="-fx-alignment: CENTER;" />
                  <TableColumn fx:id="colGhiChu" text="Ghi Chú"
                               style="-fx-alignment: CENTER_LEFT;" />
               </columns>
            </TableView>

         </children>
      </VBox>
   </children>
</AnchorPane>
