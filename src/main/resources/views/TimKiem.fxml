<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="964.0" prefWidth="1190.0"
            style="-fx-background-color: #F6F8FA;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.TimKiemController">
   <children>
      <VBox layoutX="30.0" layoutY="30.0" spacing="18.0"
            AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0"
            AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
         <children>

            <!-- Tiêu đề -->
            <Label text="Tìm Kiếm Toàn Cục"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #24292F;" />

            <!-- Search bar chính -->
            <HBox alignment="CENTER_LEFT" spacing="12.0"
                  style="-fx-background-color: white; -fx-border-color: #D0D7DE; -fx-border-radius: 6; -fx-background-radius: 6;">
               <padding><Insets topRightBottomLeft="14.0"/></padding>
               <children>
                  <Label text="🔍" style="-fx-font-size: 18px;" />
                  <TextField fx:id="txtTimKiem" prefHeight="40.0" HBox.hgrow="ALWAYS"
                             promptText="Tìm kiếm hộ khẩu, nhân khẩu, khoản thu..."
                             style="-fx-font-size: 14px; -fx-border-color: transparent; -fx-background-color: transparent;" />
                  <Button fx:id="btnTimKiem" mnemonicParsing="false"
                          onAction="#onTimKiemClick" prefHeight="40.0" prefWidth="100.0"
                          text="Tìm kiếm"
                          style="-fx-background-color: #0969DA; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
                  <Button fx:id="btnXoaTim" mnemonicParsing="false"
                          onAction="#onXoaTimClick" prefHeight="40.0" prefWidth="80.0"
                          text="Xóa"
                          style="-fx-background-color: #6E7781; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" />
               </children>
            </HBox>

            <!-- TabPane kết quả -->
            <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

               <!-- ===== TAB HỘ KHẨU ===== -->
               <tabs>
                  <Tab text="🏘 Hộ Khẩu">
                     <content>
                        <VBox spacing="12.0">
                           <padding><Insets topRightBottomLeft="14.0"/></padding>
                           <children>

                              <!-- Bộ lọc nâng cao Hộ khẩu -->
                              <HBox alignment="CENTER_LEFT" spacing="12.0"
                                    style="-fx-background-color: #EFF1F3; -fx-border-radius: 4; -fx-background-radius: 4;">
                                 <padding><Insets top="10.0" right="12.0" bottom="10.0" left="12.0"/></padding>
                                 <children>
                                    <Label text="Lọc nâng cao:" style="-fx-font-weight: bold;" />
                                    <Label text="Trạng thái:" />
                                    <ComboBox fx:id="cmbTrangThaiHK" prefHeight="34.0" prefWidth="160.0" />
                                    <Button fx:id="btnLocHK" mnemonicParsing="false"
                                            onAction="#onLocHoKhauClick" prefHeight="34.0" prefWidth="80.0"
                                            text="Lọc"
                                            style="-fx-background-color: #1E3A5F; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" />
                                    <HBox HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblSoHK" style="-fx-text-fill: #57606A; -fx-font-style: italic;" />
                                 </children>
                              </HBox>

                              <TableView fx:id="tblHoKhau" fixedCellSize="46.0" VBox.vgrow="ALWAYS">
                                 <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                 </columnResizePolicy>
                                 <columns>
                                    <TableColumn fx:id="colHkMaHo" text="Mã Hộ" sortable="true"
                                                 style="-fx-alignment: CENTER;" />
                                    <TableColumn fx:id="colHkDiaChi" text="Địa Chỉ" sortable="true"
                                                 style="-fx-alignment: CENTER_LEFT;" />
                                    <TableColumn fx:id="colHkSoTv" text="Số TV" sortable="true"
                                                 prefWidth="80.0" style="-fx-alignment: CENTER;" />
                                    <TableColumn fx:id="colHkSdt" text="Số ĐT Chủ Hộ" sortable="true"
                                                 style="-fx-alignment: CENTER;" />
                                    <TableColumn fx:id="colHkTrangThai" text="Trạng Thái" sortable="true"
                                                 prefWidth="120.0" style="-fx-alignment: CENTER;" />
                                 </columns>
                              </TableView>
                           </children>
                        </VBox>
                     </content>
                  </Tab>

                  <!-- ===== TAB NHÂN KHẨU ===== -->
                  <Tab text="👤 Nhân Khẩu">
                     <content>
                        <VBox spacing="12.0">
                           <padding><Insets topRightBottomLeft="14.0"/></padding>
                           <children>

                              <!-- Label đếm (Nhân khẩu không có bộ lọc riêng — từ khóa chính search bar) -->
                              <HBox alignment="CENTER_LEFT" spacing="12.0"
                                    style="-fx-background-color: #EFF1F3; -fx-border-radius: 4; -fx-background-radius: 4;">
                                 <padding><Insets top="10.0" right="12.0" bottom="10.0" left="12.0"/></padding>
                                 <children>
                                    <Label text="Tìm theo: Họ tên, CCCD, Số ĐT, Nghề nghiệp, Địa chỉ thường trú"
                                           style="-fx-text-fill: #57606A;" />
                                    <HBox HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblSoNK" style="-fx-text-fill: #57606A; -fx-font-style: italic;" />
                                 </children>
                              </HBox>

                              <TableView fx:id="tblNhanKhau" fixedCellSize="46.0" VBox.vgrow="ALWAYS">
                                 <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                 </columnResizePolicy>
                                 <columns>
                                    <TableColumn fx:id="colNkHoTen" text="Họ Tên" sortable="true"
                                                 style="-fx-alignment: CENTER_LEFT;" />
                                    <TableColumn fx:id="colNkCccd" text="CCCD" sortable="true"
                                                 style="-fx-alignment: CENTER;" />
                                    <TableColumn fx:id="colNkGioiTinh" text="Giới Tính" sortable="true"
                                                 prefWidth="90.0" style="-fx-alignment: CENTER;" />
                                    <TableColumn fx:id="colNkNgheNghiep" text="Nghề Nghiệp" sortable="true"
                                                 style="-fx-alignment: CENTER_LEFT;" />
                                    <TableColumn fx:id="colNkSdt" text="Số ĐT" sortable="true"
                                                 style="-fx-alignment: CENTER;" />
                                    <TableColumn fx:id="colNkTrangThai" text="Trạng Thái" sortable="true"
                                                 prefWidth="110.0" style="-fx-alignment: CENTER;" />
                                 </columns>
                              </TableView>
                           </children>
                        </VBox>
                     </content>
                  </Tab>

                  <!-- ===== TAB KHOẢN THU ===== -->
                  <Tab text="💰 Khoản Thu">
                     <content>
                        <VBox spacing="12.0">
                           <padding><Insets topRightBottomLeft="14.0"/></padding>
                           <children>

                              <!-- Bộ lọc nâng cao Khoản thu -->
                              <HBox alignment="CENTER_LEFT" spacing="12.0"
                                    style="-fx-background-color: #EFF1F3; -fx-border-radius: 4; -fx-background-radius: 4;">
                                 <padding><Insets top="10.0" right="12.0" bottom="10.0" left="12.0"/></padding>
                                 <children>
                                    <Label text="Lọc nâng cao:" style="-fx-font-weight: bold;" />
                                    <Label text="Loại:" />
                                    <ComboBox fx:id="cmbLoaiKT" prefHeight="34.0" prefWidth="140.0" />
                                    <Label text="Trạng thái:" />
                                    <ComboBox fx:id="cmbTrangThaiKT" prefHeight="34.0" prefWidth="150.0" />
                                    <Button fx:id="btnLocKT" mnemonicParsing="false"
                                            onAction="#onLocKhoanThuClick" prefHeight="34.0" prefWidth="80.0"
                                            text="Lọc"
                                            style="-fx-background-color: #1E3A5F; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand;" />
                                    <HBox HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblSoKT" style="-fx-text-fill: #57606A; -fx-font-style: italic;" />
                                 </children>
                              </HBox>

                              <TableView fx:id="tblKhoanThu" fixedCellSize="46.0" VBox.vgrow="ALWAYS">
                                 <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                 </columnResizePolicy>
                                 <columns>
                                    <TableColumn fx:id="colKtMaKhoan" text="Mã Khoản" sortable="true"
                                                 prefWidth="120.0" style="-fx-alignment: CENTER;" />
                                    <TableColumn fx:id="colKtTenKhoan" text="Tên Khoản Thu" sortable="true"
                                                 style="-fx-alignment: CENTER_LEFT;" />
                                    <TableColumn fx:id="colKtLoai" text="Loại" sortable="true"
                                                 prefWidth="110.0" style="-fx-alignment: CENTER;" />
                                    <TableColumn fx:id="colKtSoTien" text="Số Tiền (VNĐ)" sortable="true"
                                                 prefWidth="140.0" style="-fx-alignment: CENTER_RIGHT;" />
                                    <TableColumn fx:id="colKtTrangThai" text="Trạng Thái" sortable="true"
                                                 prefWidth="120.0" style="-fx-alignment: CENTER;" />
                                 </columns>
                              </TableView>
                           </children>
                        </VBox>
                     </content>
                  </Tab>

               </tabs>
            </TabPane>

         </children>
      </VBox>
   </children>
</AnchorPane>
